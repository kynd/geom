---
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

interface Props {
  title: string;
  slug: string;
  isProse?: boolean;
}

const { title, slug, isProse = false } = Astro.props;

const navItems = [
  { label: 'Geom',               href: `${base}/`,                   slug: '' },
  { label: 'Parametric shapes',  href: `${base}/parametric-shapes`,  slug: 'parametric-shapes' },
  { label: 'Sound process',      href: `${base}/sound-process`,      slug: 'sound-process' },
  { label: 'Sound analysis',     href: `${base}/sound-analysis`,     slug: 'sound-analysis' },
];
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title === 'Geom' ? 'Geom' : `${title} — Geom`}</title>
  <script is:inline>
    (function() {
      var f = localStorage.getItem('font-mode') || 'serif';
      document.documentElement.setAttribute('data-font', f);
    })();
  </script>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Lora:ital,wght@0,400;0,500;0,600;1,400&family=Sora:wght@300;400;500;600&family=Google+Sans+Code:ital,wght@0,400;0,500;1,400&display=swap"
    rel="stylesheet"
  />
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/katex@0.16.11/dist/katex.min.css" crossorigin="anonymous" />
  <script defer src="https://cdn.jsdelivr.net/npm/katex@0.16.11/dist/katex.min.js" crossorigin="anonymous"></script>
  <script defer src="https://cdn.jsdelivr.net/npm/katex@0.16.11/dist/contrib/auto-render.min.js" crossorigin="anonymous"></script>
  <script is:inline>
    document.addEventListener('DOMContentLoaded', function() {
      function tryRender() {
        if (typeof renderMathInElement !== 'undefined') {
          renderMathInElement(document.body, {
            delimiters: [
              { left: '\\(', right: '\\)', display: false },
              { left: '\\[', right: '\\]', display: true }
            ]
          });
        } else {
          setTimeout(tryRender, 50);
        }
      }
      tryRender();
    });
  </script>
  <style is:global>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg:             #ffffff;
      --fg:             #343434;
      --fg-muted:       #777777;
      --border:         #e8e8e8;
      --sidebar-width:  280px;
      --header-height:  64px;
      --font-body:      'Sora', sans-serif;
      --font-code:      'Google Sans Code', 'Fira Mono', monospace;
    }
    html[data-font="serif"] { --font-body: 'Lora', serif; }

    html, body {
      background: var(--bg);
      color: var(--fg);
      font-family: var(--font-body);
      font-size: 18px;
      line-height: 1.7;
      min-height: 100vh;
    }

    .shell { display: flex; min-height: 100vh; }

    .topbar {
      position: fixed;
      top: 0; left: 0; right: 0;
      height: var(--header-height);
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0 1rem;
      z-index: 100;
      pointer-events: none;
    }
    .topbar-controls {
      display: flex; align-items: center;
      background: rgba(255,255,255,0.76);
      border-radius: 8px;
      backdrop-filter: blur(6px);
      -webkit-backdrop-filter: blur(6px);
      pointer-events: all;
    }
    .topbar-controls-left { padding: 0.22rem; }
    .topbar-controls-right { padding: 0.22rem 0.55rem; }
    .topbar-toggle {
      display: flex; align-items: center; justify-content: center;
      width: 30px; height: 30px;
      background: none; border: none; cursor: pointer;
      color: var(--fg); border-radius: 5px; transition: background 0.15s;
    }
    .topbar-toggle:hover { background: rgba(0,0,0,0.06); }
    .topbar-font-switcher { display: flex; align-items: center; gap: 0.25rem; }
    .font-opt {
      background: none; border: none; cursor: pointer;
      padding: 0.2rem 0.1rem; font-size: 0.75rem;
      color: var(--fg-muted); letter-spacing: 0.01em; transition: color 0.15s;
    }
    .font-opt:hover { color: var(--fg); }
    .font-opt.active { color: var(--fg); font-weight: 600; }
    .font-sep { color: #ccc; font-size: 0.75rem; user-select: none; }

    .sidebar-backdrop {
      display: none; position: fixed; inset: 0;
      background: rgba(0,0,0,0.08); z-index: 98;
    }
    .sidebar {
      position: fixed; top: 0; left: 0; bottom: 0;
      width: var(--sidebar-width); background: var(--bg);
      overflow-y: auto; z-index: 101;
      transform: translateX(calc(-1 * var(--sidebar-width)));
      transition: transform 0.22s ease;
      padding: 1rem 0 2rem;
    }
    .shell.sidebar-open .sidebar { transform: translateX(0); box-shadow: 4px 0 24px rgba(0,0,0,0.07); }
    .shell.no-transition .sidebar,
    .shell.no-transition .main-wrap { transition: none !important; }
    .shell.sidebar-open .sidebar-backdrop { display: block; }

    .sidebar-nav { list-style: none; padding: 0; margin: 0; }
    .sidebar-nav a {
      display: block; font-family: 'Sora', sans-serif;
      font-size: 0.82rem; color: var(--fg-muted);
      text-decoration: none; padding: 0.42rem 1.25rem;
      transition: background 0.1s;
    }
    .sidebar-nav a:hover { background: #f4f4f4; color: var(--fg); }
    .sidebar-nav a.current { font-weight: 600; color: var(--fg); background: #f0f0f0; }
    .sidebar-nav a.sub { padding-left: 2rem; font-size: 0.78rem; }

    .main-wrap {
      flex: 1; margin-top: var(--header-height);
      transition: margin-left 0.22s ease; min-width: 0;
    }
    .shell.sidebar-open .main-wrap { margin-left: var(--sidebar-width); }

    .main-inner { max-width: 1080px; margin: 0 auto; padding: 3rem 2rem 6rem; }

    h1 {
      font-size: 3rem; font-weight: 300;
      letter-spacing: -0.03em; margin-bottom: 3.5rem;
    }

    /* Demo sections */
    .demo-section { margin-bottom: 4rem; }
    .demo-header { display: flex; align-items: baseline; gap: 1.2rem; margin-bottom: 1rem; }
    .demo-header h2 { font-size: 1.1rem; font-weight: 500; letter-spacing: -0.01em; }
    .demo-header a {
      font-family: var(--font-code); font-size: 0.78rem;
      color: var(--fg-muted); text-decoration: none;
      border-bottom: 1px solid var(--border); padding-bottom: 1px;
      transition: color 0.15s, border-color 0.15s;
    }
    .demo-header a:hover { color: var(--fg); border-color: var(--fg); }
    .demo-embed {
      width: 960px; height: 540px;
      max-width: 100%; position: relative;
      border: 1px solid var(--border); border-radius: 4px; overflow: hidden;
    }
    .demo-embed iframe {
      width: 960px; height: 540px; border: none; display: block;
      transform-origin: top left;
    }

    /* Prose */
    .prose {
      max-width: 640px; margin-top: 2.5rem;
      font-size: 1rem; line-height: 1.75; color: var(--fg);
    }
    .prose p { margin-bottom: 1.1rem; }
    .prose em { font-style: italic; }
    .prose a {
      color: var(--fg); text-decoration: underline;
      text-decoration-color: var(--border); text-underline-offset: 3px;
      transition: text-decoration-color 0.15s;
    }
    .prose a:hover { text-decoration-color: var(--fg); }
    .prose .math-block { margin: 1.4rem 0; text-align: left; overflow-x: auto; }
    .prose h2 {
      font-size: 1rem; font-weight: 600; letter-spacing: -0.01em;
      margin-top: 2.5rem; margin-bottom: 0.8rem;
    }
    .prose ul { list-style: disc; padding-left: 1.4rem; }
    .prose ul li { margin-bottom: 0.4rem; }
    .prose code {
      font-family: var(--font-code); font-size: 0.88em;
      background: #f5f5f5; padding: 0.1em 0.35em; border-radius: 3px;
    }

    @media (max-width: 768px) {
      .shell.sidebar-open .main-wrap { margin-left: 0; }
      .main-inner { padding: 1.5rem 1.25rem 3rem; }
      h1 { font-size: 2rem; }
      .prose { max-width: 100%; }
    }
  </style>
</head>
<body>
  <header class="topbar">
    <div class="topbar-controls topbar-controls-left">
      <button class="topbar-toggle" id="sidebar-toggle" aria-label="Toggle sidebar">
        <svg width="18" height="14" viewBox="0 0 18 14" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round">
          <line x1="0" y1="1" x2="18" y2="1"/>
          <line x1="0" y1="7" x2="18" y2="7"/>
          <line x1="0" y1="13" x2="18" y2="13"/>
        </svg>
      </button>
    </div>
    <div class="topbar-controls topbar-controls-right">
      <div class="topbar-font-switcher">
        <button class="font-opt" id="font-btn-serif" style="font-family:'Lora',serif">Serif</button>
        <span class="font-sep">|</span>
        <button class="font-opt" id="font-btn-sans" style="font-family:'Sora',sans-serif">Sans</button>
      </div>
    </div>
  </header>

  <div class="shell" id="app-shell">
    <div class="sidebar-backdrop" id="sidebar-backdrop"></div>

    <nav class="sidebar" aria-label="Site navigation">
      <ul class="sidebar-nav">
        {navItems.map(item => (
          <li>
            <a href={item.href} class={item.slug === slug ? 'current' : ''}>
              {item.label}
            </a>
          </li>
        ))}
        {slug === 'parametric-shapes' && (
          <>
            <li><a href="#sdf-raymarching" class="sub">SDF ray marching</a></li>
            <li><a href="#scalar-fields" class="sub">Scalar fields</a></li>
          </>
        )}
        {slug === 'sound-process' && (
          <>
            <li><a href="#what-is-an-fft" class="sub">What is an FFT?</a></li>
            <li><a href="#log-transform" class="sub">Log transform</a></li>
          </>
        )}
      </ul>
    </nav>

    <main class="main-wrap">
      <div class="main-inner">
        <h1>{title}</h1>
        {isProse ? (
          <div class="prose">
            <slot />
          </div>
        ) : (
          <slot />
        )}
      </div>
    </main>
  </div>

  <script>
    const shell     = document.getElementById('app-shell')!;
    const toggleBtn = document.getElementById('sidebar-toggle')!;
    const backdrop  = document.getElementById('sidebar-backdrop')!;

    const isMobile = () => window.innerWidth <= 768;

    // Scale fixed-size demo iframes to fit their container on narrow screens
    function scaleDemoEmbeds() {
      document.querySelectorAll<HTMLElement>('.demo-embed').forEach(wrap => {
        const iframe = wrap.querySelector<HTMLIFrameElement>('iframe');
        if (!iframe) return;
        const scale = Math.min(1, wrap.clientWidth / 960);
        iframe.style.transform = scale < 1 ? `scale(${scale})` : '';
        wrap.style.height      = scale < 1 ? `${Math.round(540 * scale)}px` : '';
      });
    }
    window.addEventListener('resize', scaleDemoEmbeds);
    // Run after layout settles
    requestAnimationFrame(scaleDemoEmbeds);

    function applyOpen(open: boolean) {
      shell.classList.toggle('sidebar-open', open);
      localStorage.setItem('sidebar-open', String(open));
      // Re-scale iframes after sidebar transition completes
      setTimeout(scaleDemoEmbeds, 250);
    }
    shell.classList.add('no-transition');
    // On mobile, default to closed regardless of stored state
    const storedOpen = localStorage.getItem('sidebar-open') === 'true';
    applyOpen(isMobile() ? false : storedOpen);
    requestAnimationFrame(() => shell.classList.remove('no-transition'));
    toggleBtn.addEventListener('click', () => applyOpen(!shell.classList.contains('sidebar-open')));
    backdrop.addEventListener('click',  () => applyOpen(false));

    const btnSerif = document.getElementById('font-btn-serif')!;
    const btnSans  = document.getElementById('font-btn-sans')!;
    function applyFont(mode: string) {
      document.documentElement.setAttribute('data-font', mode);
      localStorage.setItem('font-mode', mode);
      btnSerif.classList.toggle('active', mode === 'serif');
      btnSans.classList.toggle('active',  mode === 'sans');
    }
    applyFont(localStorage.getItem('font-mode') || 'serif');
    btnSerif.addEventListener('click', () => applyFont('serif'));
    btnSans.addEventListener('click',  () => applyFont('sans'));
  </script>
</body>
</html>
