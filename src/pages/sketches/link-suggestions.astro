---
import PageLayout from '../../layouts/PageLayout.astro';
---

<PageLayout title="[Sketch] Link suggestions" slug="sketches/link-suggestions">

<style>
  .ls-intro {
    font-size: 0.82rem; color: var(--fg-muted); max-width: 700px;
    margin-bottom: 2.5rem; line-height: 1.65;
  }

  .ls-page {
    margin-bottom: 3rem;
  }
  .ls-page-heading {
    font-size: 0.95rem; font-weight: 600; color: var(--fg);
    margin-bottom: 0.2rem;
    padding-bottom: 0.4rem;
    border-bottom: 1px solid var(--border);
  }
  .ls-page-path {
    font-family: var(--font-code); font-size: 0.72rem;
    color: var(--fg-muted); margin-bottom: 1rem;
  }

  .ls-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.82rem;
  }
  .ls-table th {
    text-align: left;
    font-size: 0.72rem; font-weight: 600;
    color: var(--fg-muted); letter-spacing: 0.06em; text-transform: uppercase;
    padding: 0.3rem 1rem 0.3rem 0;
    border-bottom: 1px solid var(--border);
  }
  .ls-table td {
    vertical-align: top;
    padding: 0.45rem 1rem 0.45rem 0;
    border-bottom: 1px solid var(--border);
    color: var(--fg-muted);
    line-height: 1.5;
  }
  .ls-table td:first-child {
    font-family: var(--font-code); font-size: 0.78rem;
    color: var(--fg); white-space: nowrap;
  }
  .ls-table a {
    color: var(--fg); text-decoration: underline;
    text-underline-offset: 2px;
  }
  .ls-table .note {
    font-size: 0.72rem; color: var(--fg-muted); margin-top: 0.15rem;
  }
  .ls-already {
    opacity: 0.45;
  }
  .ls-already td:first-child::before {
    content: '✓ ';
    color: var(--fg-muted);
  }
  .tag-strong { color: var(--fg); font-weight: 500; }
  .tag-maybe  { color: var(--fg-muted); font-style: italic; }
</style>

<p class="ls-intro">
  Suggested inline links from geom written content to kynd.info writing pages.
  Rows marked ✓ are already linked. All others are new suggestions.
  "Phrase" is the literal text in the source; "Link text" is the proposed anchor text (may differ slightly).
</p>

<!-- ── Geom (index) ─────────────────────────────────────────────────── -->
<div class="ls-page">
  <div class="ls-page-heading">Geom</div>
  <div class="ls-page-path">src/content/pages/index.md</div>
  <table class="ls-table">
    <thead>
      <tr><th>Phrase in text</th><th>Link text</th><th>Target page</th></tr>
    </thead>
    <tbody>
      <tr class="ls-already">
        <td>Sketching with Math and Quasi Physics</td>
        <td>Sketching with Math and Quasi Physics</td>
        <td><a href="https://www.kynd.info/writing/sketching-with-math-and-quasi-physics" target="_blank" rel="noopener">Sketching with Math and Quasi Physics</a></td>
      </tr>
      <tr class="ls-already">
        <td>Bézier curves</td>
        <td>Bézier curves</td>
        <td><a href="https://www.kynd.info/writing/be/" target="_blank" rel="noopener">Bézier and Spline</a></td>
      </tr>
      <tr class="ls-already">
        <td>Fourier transform</td>
        <td>Fourier transform</td>
        <td><a href="https://www.kynd.info/writing/fourier-series/" target="_blank" rel="noopener">Fourier Series</a></td>
      </tr>
      <tr class="ls-already">
        <td>random and noise functions</td>
        <td>random and noise functions</td>
        <td><a href="https://www.kynd.info/writing/taming-randomness/" target="_blank" rel="noopener">Taming Randomness</a></td>
      </tr>
    </tbody>
  </table>
</div>

