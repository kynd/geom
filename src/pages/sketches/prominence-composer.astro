---
import PageLayout from '../../layouts/PageLayout.astro';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<PageLayout title="Prominence composer" slug="sketches/prominence-composer">
  <div class="monologue">
    Each stem has its own shape. The most prominent one at any moment takes the stage.
  </div>

  <section class="demo-section" id="prominence-composer">
    <div class="demo-header">
      <h2>Prominence composer</h2>
      <a href={`${base}/sketches/prominence-composer/demo/index.html`} target="_blank" rel="noopener">open full size ↗</a>
    </div>
    <div class="demo-embed">
      <iframe src={`${base}/sketches/prominence-composer/demo/index.html?embedded`} title="Prominence composer" scrolling="no"></iframe>
    </div>
    <div class="prose">
      <p>
        One shape per stem. The most prominent stem at any moment takes the full canvas —
        its shape, lighting, and bloom filling the frame while everything else waits offscreen.
        When all stems are close in prominence or the signal is quiet, the last winner holds
        until something new breaks through.
      </p>
      <p>
        Every stem is independently configurable: open Settings to assign each one a shape type
        and deformation effect. Lighting and bloom are global — one set of controls shared across all stems.
        Use Solo to lock a single stem and audition its visual in isolation.
        Drag to rotate the camera; shift-drag to pan; scroll or pinch to zoom.
      </p>
    </div>
  </section>
</PageLayout>
