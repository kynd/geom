---
import PageLayout from '../../layouts/PageLayout.astro';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<PageLayout title="Prominence composer" slug="sketches/prominence-composer">
  <div class="monologue">
    Each stem has its own shape. The most prominent one at any moment takes the stage.
  </div>
  <section class="demo-section" id="prominence-composer">
    <div class="demo-header">
      <h2>Prominence composer</h2>
      <a href={`${base}/sketches/prominence-composer/index.html`} target="_blank" rel="noopener">open full size ↗</a>
    </div>
    <div class="demo-embed">
      <iframe src={`${base}/sketches/prominence-composer/index.html?embedded`} title="Prominence composer" scrolling="no"></iframe>
    </div>
  </section>
</PageLayout>
