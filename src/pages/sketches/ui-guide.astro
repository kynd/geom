---
import PageLayout from '../../layouts/PageLayout.astro';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---
<PageLayout title="UI Component Guide" slug="sketches/ui-guide">
  <p>Component definitions and layout patterns for all Geom demos.</p>
  <div class="demo-embed" style="margin-top: 1.5rem;">
    <iframe src={`${base}/sketches/ui-guide/`} width="960" height="800" style="border:none;width:100%;height:800px;border-radius:4px;overflow:auto;" scrolling="yes"></iframe>
  </div>
</PageLayout>
